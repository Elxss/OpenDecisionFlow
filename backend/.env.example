# Copy this file to .env and adjust the values
# cp .env.example .env

# ─── Admin account ────────────────────────────────────────────────────────────
# Set these before the first run to avoid using the default credentials.
# If omitted, the account is created as "admin" / "admin" and the user
# will be forced to change the password on first login.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Path to the SQLite database
# Docker: /app/data/data.db  (with a volume mounted on /app/data)
# Dev:    ./data.db
DB_PATH=./data.db

# Allowed CORS origin — your frontend URL (no trailing slash)
# Dev:        http://localhost:5173
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Set to true in production (requires HTTPS)
COOKIE_SECURE=false

# Max request body size in bytes (512 KB by default)
MAX_BODY_SIZE=524288

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DURATION_DAYS=7

# ─── Rate limiting ────────────────────────────────────────────────────────────
# All values are request counts per RATE_WINDOW_MS
RATE_WINDOW_MS=60000

RATE_LIMIT_AUTH=10           # login, register
RATE_LIMIT_STRICT=20         # guest, redeem
RATE_LIMIT_SEARCH=10         # questionnaire list
RATE_LIMIT_DECISIONFLOW=15   # opening a DecisionFlow
